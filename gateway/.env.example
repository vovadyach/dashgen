# Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# URL of the metrics service
# Local: http://localhost:8080
# Production: https://your-metrics.up.railway.app
METRICS_BASE_URL=http://localhost:8080

# Port the gateway listens on (Railway will override this in production)
PORT=3000

# Comma-separated list of allowed CORS origins
# Local: http://localhost:5173
# Production: also add your Vercel frontend URL
ALLOWED_ORIGINS=http://localhost:5173